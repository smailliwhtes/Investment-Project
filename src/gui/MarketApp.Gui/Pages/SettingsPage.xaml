<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MarketApp.Gui.Pages.SettingsPage"
             Title="Settings">
  <ContentPage.Resources>
    <ResourceDictionary>
      <Style x:Key="InfoIconButtonStyle" TargetType="Button">
        <Setter Property="Text" Value="i" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="MinimumWidthRequest" Value="22" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="22" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="BackgroundColor" Value="#2F2F2F" />
        <Setter Property="BorderColor" Value="#4E6FA4" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="#FFFFFF" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">
      <HorizontalStackLayout Spacing="6">
        <Label Text="Engine settings" FontAttributes="Bold" />
        <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="engine_settings" Clicked="OnInfoClicked" />
      </HorizontalStackLayout>
      <Entry Placeholder="Config path" Text="{Binding ConfigPath}" />
      <Entry Placeholder="Python path" Text="{Binding PythonPath}" />

      <HorizontalStackLayout Spacing="6">
        <Label Text="Secrets" FontAttributes="Bold" />
        <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="secrets" Clicked="OnInfoClicked" />
      </HorizontalStackLayout>
      <Entry Placeholder="Finnhub API key" Text="{Binding FinnhubKey}" />
      <Entry Placeholder="TwelveData API key" Text="{Binding TwelveDataKey}" />
      <Entry Placeholder="AlphaVantage API key" Text="{Binding AlphaVantageKey}" />
      <Button Text="Save secrets" Command="{Binding SaveSecretsCommand}" />

      <Label Text="{Binding StatusMessage}" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
