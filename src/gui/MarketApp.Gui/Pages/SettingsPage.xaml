<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MarketApp.Gui.Pages.SettingsPage"
             Title="Settings">
  <ContentPage.Resources>
    <ResourceDictionary>
      <Style x:Key="InfoIconButtonStyle" TargetType="Button">
        <Setter Property="Text" Value="i" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="MinimumWidthRequest" Value="22" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="22" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="BackgroundColor" Value="#2F2F2F" />
        <Setter Property="BorderColor" Value="#4E6FA4" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="#FFFFFF" />
      </Style>

      <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
      </Style>

      <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
      </Style>

      <Style x:Key="InputEntryStyle" TargetType="Entry">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="40" />
      </Style>

      <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="38" />
        <Setter Property="Padding" Value="14,8" />
      </Style>

      <Style x:Key="BodyLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <ScrollView>
    <VerticalStackLayout Padding="18" Spacing="14">
      <Label Text="Settings" Style="{StaticResource PageTitleStyle}" />

      <Frame Padding="14">
        <VerticalStackLayout Spacing="10">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Engine settings" Style="{StaticResource SectionTitleStyle}" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="engine_settings" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>
          <Entry Style="{StaticResource InputEntryStyle}" Placeholder="Config path" Text="{Binding ConfigPath}" />
          <Entry Style="{StaticResource InputEntryStyle}" Placeholder="Python path" Text="{Binding PythonPath}" />
        </VerticalStackLayout>
      </Frame>

      <Frame Padding="14">
        <VerticalStackLayout Spacing="10">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Secrets" Style="{StaticResource SectionTitleStyle}" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="secrets" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>
          <Entry Style="{StaticResource InputEntryStyle}" IsPassword="True" Placeholder="Finnhub API key" Text="{Binding FinnhubKey}" />
          <Entry Style="{StaticResource InputEntryStyle}" IsPassword="True" Placeholder="TwelveData API key" Text="{Binding TwelveDataKey}" />
          <Entry Style="{StaticResource InputEntryStyle}" IsPassword="True" Placeholder="AlphaVantage API key" Text="{Binding AlphaVantageKey}" />
          <Button Style="{StaticResource ActionButtonStyle}" Text="Save secrets" Command="{Binding SaveSecretsCommand}" />
        </VerticalStackLayout>
      </Frame>

      <Label Style="{StaticResource BodyLabelStyle}" Text="{Binding StatusMessage}" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
