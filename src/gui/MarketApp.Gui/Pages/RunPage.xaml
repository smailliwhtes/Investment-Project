<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:MarketApp.Gui.Converters"
             x:Class="MarketApp.Gui.Pages.RunPage"
             Title="Run">
  <ContentPage.Resources>
    <ResourceDictionary>
      <converters:InverseBoolConverter x:Key="InverseBoolConverter" />

      <Style x:Key="InfoIconButtonStyle" TargetType="Button">
        <Setter Property="Text" Value="i" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="MinimumWidthRequest" Value="22" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="22" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="BackgroundColor" Value="#2F2F2F" />
        <Setter Property="BorderColor" Value="#4E6FA4" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="#FFFFFF" />
      </Style>

      <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
      </Style>

      <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
      </Style>

      <Style x:Key="FieldLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
      </Style>

      <Style x:Key="InputEntryStyle" TargetType="Entry">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="40" />
      </Style>

      <Style x:Key="ActionButtonStyle" TargetType="Button">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="38" />
        <Setter Property="Padding" Value="14,8" />
      </Style>

      <Style x:Key="TableHeaderStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
      </Style>

      <Style x:Key="TableCellStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineBreakMode" Value="TailTruncation" />
        <Setter Property="MaxLines" Value="1" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <ScrollView>
    <VerticalStackLayout Padding="18" Spacing="14">
      <HorizontalStackLayout Spacing="6">
        <Label Text="Start a run" Style="{StaticResource PageTitleStyle}" />
        <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="run_orchestration" Clicked="OnInfoClicked" />
      </HorizontalStackLayout>
      <Label Style="{StaticResource FieldLabelStyle}" Text="Most users only need the first section. The other sections are optional setup tools." />

      <Frame Padding="14" Margin="0,2,0,0">
        <VerticalStackLayout Spacing="10">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Basic run" Style="{StaticResource SectionTitleStyle}" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="config_path" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>

          <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
              <Label Text="Config file" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="config_path" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Text="{Binding ConfigPath}" Grid.Row="0" Grid.Column="1" />

            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
              <Label Text="Save results to" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="output_directory" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Text="{Binding OutputDirectory}" Grid.Row="1" Grid.Column="1" />

            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
              <Label Text="Python runner" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="python_path" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Text="{Binding PythonPath}" Grid.Row="2" Grid.Column="1" />

            <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="18">
              <HorizontalStackLayout Spacing="6">
                <CheckBox IsChecked="{Binding RunBuildLinkedAfterRun}" />
                <Label Text="Build event links after the run" Style="{StaticResource FieldLabelStyle}" />
              </HorizontalStackLayout>
              <HorizontalStackLayout Spacing="6">
                <CheckBox IsChecked="{Binding RunEvaluateAfterRun}" />
                <Label Text="Build the model review after the run" Style="{StaticResource FieldLabelStyle}" />
              </HorizontalStackLayout>
            </HorizontalStackLayout>

            <FlexLayout Grid.Row="4" Grid.ColumnSpan="2" Direction="Row" Wrap="Wrap" AlignItems="Start" JustifyContent="Start">
              <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8" Text="Check setup" Command="{Binding ValidateConfigCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
              <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8" Text="Start run" Command="{Binding StartCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
              <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8" Text="Cancel run" Command="{Binding CancelCommand}" IsEnabled="{Binding IsRunning}" />
            </FlexLayout>
          </Grid>
        </VerticalStackLayout>
      </Frame>

      <Frame Padding="14">
        <VerticalStackLayout Spacing="10">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Advanced path setup" Style="{StaticResource SectionTitleStyle}" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="preprocessed_snapshot" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>
          <Label Style="{StaticResource FieldLabelStyle}" Text="You can ignore this section unless you already have cleaned files and want the app to use them." />

          <HorizontalStackLayout Spacing="6">
            <CheckBox IsChecked="{Binding UsePreprocessedSnapshot}" />
            <Label Text="Use saved cleaned-file paths" Style="{StaticResource FieldLabelStyle}" />
          </HorizontalStackLayout>

          <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
              <Label Text="Manifest file" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="manifest_json" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="0" Grid.Column="1" Text="{Binding PreprocessorManifestPath}" />

            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
              <Label Text="Price registry file" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="market_registry_json" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="1" Grid.Column="1" Text="{Binding MarketRegistryPath}" />

            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
              <Label Text="Event registry file" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="gdelt_registry_json" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="2" Grid.Column="1" Text="{Binding GdeltRegistryPath}" />

            <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
              <Label Text="Joined event file" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="gdelt_join_ready_csv" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="3" Grid.Column="1" Text="{Binding GdeltJoinReadyCsvPath}" />
          </Grid>

          <Button Style="{StaticResource ActionButtonStyle}" Text="Use advanced paths" Command="{Binding ApplyPreprocessedSnapshotCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
          <Label Text="{Binding PreprocessedStatus}" FontSize="13" LineBreakMode="WordWrap" />
        </VerticalStackLayout>
      </Frame>

      <Frame Padding="14">
        <VerticalStackLayout Spacing="10">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Optional data import and processing" Style="{StaticResource SectionTitleStyle}" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="ingest_process" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>
          <Label Style="{StaticResource FieldLabelStyle}" Text="Use this only when you want to pull in new price or event files." />

          <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
            <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
              <Label Text="Price-data source folder" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="market_source" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="0" Grid.Column="1" Text="{Binding MarketDataSourceDirectory}" />

            <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
              <Label Text="Price-data app folder" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="market_dest" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="1" Grid.Column="1" Text="{Binding MarketDataDestinationDirectory}" />

            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
              <Label Text="Event-data source folder" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="corpus_source" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="2" Grid.Column="1" Text="{Binding CorpusDataSourceDirectory}" />

            <HorizontalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
              <Label Text="Event-data app folder" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="corpus_dest" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="3" Grid.Column="1" Text="{Binding CorpusDataDestinationDirectory}" />

            <HorizontalStackLayout Grid.Row="4" Grid.Column="0" Spacing="6">
              <Label Text="Cleaned event folder" Style="{StaticResource FieldLabelStyle}" />
              <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="corpus_normalized" Clicked="OnInfoClicked" />
            </HorizontalStackLayout>
            <Entry Style="{StaticResource InputEntryStyle}" Grid.Row="4" Grid.Column="1" Text="{Binding CorpusNormalizedDirectory}" />
          </Grid>

          <FlexLayout Direction="Row" Wrap="Wrap" AlignItems="Start" JustifyContent="Start">
            <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8" Text="Import price files" Command="{Binding IngestMarketDataCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
            <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8" Text="Import event files" Command="{Binding IngestCorpusDataCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
            <Button Style="{StaticResource ActionButtonStyle}" Margin="0,0,8,8" Text="Run optional processing" Command="{Binding ProcessLatestDataCommand}" IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBoolConverter}}" />
          </FlexLayout>
        </VerticalStackLayout>
      </Frame>

      <ProgressBar Progress="{Binding Progress}" />
      <Label Text="{Binding Status}" FontSize="14" />

      <Frame Padding="14">
        <VerticalStackLayout Spacing="8">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Run progress" Style="{StaticResource SectionTitleStyle}" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="progress_events" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>
          <Label Style="{StaticResource FieldLabelStyle}" Text="Use this list only if you want to watch each step or troubleshoot a failure." />

          <ScrollView HeightRequest="320">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding ProgressEvents}" Spacing="2">
              <BindableLayout.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="84,110,*,72" Padding="0,2" ColumnSpacing="8" MinimumHeightRequest="24">
                    <Label Style="{StaticResource TableCellStyle}" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" />
                    <Label Style="{StaticResource TableCellStyle}" Text="{Binding Type}" FontAttributes="Bold" Grid.Column="1" />
                    <Label Style="{StaticResource TableCellStyle}" Text="{Binding Message}" Grid.Column="2" />
                    <Label Style="{StaticResource TableCellStyle}" Text="{Binding Pct, StringFormat='{}{0:P0}'}" Grid.Column="3" HorizontalTextAlignment="End" />
                  </Grid>
                </DataTemplate>
              </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
          </ScrollView>
        </VerticalStackLayout>
      </Frame>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
