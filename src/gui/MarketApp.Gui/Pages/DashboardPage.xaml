<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MarketApp.Gui.Pages.DashboardPage"
             Title="Dashboard"
             BackgroundColor="#E8EDF6">
  <ContentPage.Resources>
    <Color x:Key="DashboardNavy">#1F3A5A</Color>
    <Color x:Key="DashboardNavyDark">#182F4A</Color>
    <Color x:Key="DashboardSlate">#5E718A</Color>
    <Color x:Key="DashboardText">#17324B</Color>
    <Color x:Key="DashboardMuted">#66788E</Color>
    <Color x:Key="DashboardSurface">#F8FAFD</Color>
    <Color x:Key="DashboardSurfaceStrong">#FFFFFF</Color>
    <Color x:Key="DashboardLine">#D5DEE8</Color>
    <Color x:Key="DashboardSuccess">#178A58</Color>
    <Color x:Key="DashboardDanger">#C24E3E</Color>

    <Style x:Key="SectionHeaderStyle" TargetType="Label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="TextColor" Value="{StaticResource DashboardSlate}" />
      <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="Label">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontAttributes" Value="Bold" />
      <Setter Property="TextColor" Value="{StaticResource White}" />
    </Style>

    <Style x:Key="BodyTitleStyle" TargetType="Label">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontAttributes" Value="Bold" />
      <Setter Property="TextColor" Value="{StaticResource DashboardText}" />
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="Label">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="TextColor" Value="{StaticResource DashboardMuted}" />
      <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style x:Key="MetricValueStyle" TargetType="Label">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontAttributes" Value="Bold" />
      <Setter Property="TextColor" Value="{StaticResource DashboardText}" />
    </Style>
  </ContentPage.Resources>

  <Shell.TitleView>
    <Grid ColumnDefinitions="*" Padding="0,0,4,0">
      <Label Text="Dashboard"
             FontSize="20"
             FontAttributes="Bold"
             HorizontalOptions="Center"
             VerticalOptions="Center" />
    </Grid>
  </Shell.TitleView>

  <ScrollView>
    <VerticalStackLayout Padding="22,16,22,28" Spacing="18">
      <Border Padding="22"
              StrokeThickness="0"
              Background="#1F3A5A">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="26" />
        </Border.StrokeShape>
        <Border.Shadow>
          <Shadow Brush="#2A3D54"
                  Offset="0,12"
                  Radius="24"
                  Opacity="0.20" />
        </Border.Shadow>
        <Grid ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto"
              ColumnSpacing="18"
              RowSpacing="14">
          <VerticalStackLayout Spacing="8">
            <Label Text="{Binding HeaderTitle}"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White" />
            <Label Text="{Binding HeaderSubtitle}"
                   FontSize="14"
                   TextColor="#D9E4F2"
                   LineBreakMode="WordWrap" />
          </VerticalStackLayout>

          <VerticalStackLayout Grid.Column="1"
                               Spacing="10"
                               HorizontalOptions="End"
                               VerticalOptions="Center">
            <Border Padding="12,8"
                    Stroke="#5E718A"
                    StrokeThickness="1"
                    Background="#2A4B70">
              <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
              </Border.StrokeShape>
              <Label Text="{Binding LastRun.LastDateMax, StringFormat='Fresh through {0}'}"
                     TextColor="White"
                     FontSize="12" />
            </Border>
            <Border Padding="12,8"
                    Stroke="#5E718A"
                    StrokeThickness="1"
                    Background="#2A4B70">
              <Border.StrokeShape>
                <RoundRectangle CornerRadius="18" />
              </Border.StrokeShape>
              <Label Text="{Binding LastRun.WorstLagDays, StringFormat='Oldest data {0}d old'}"
                     TextColor="White"
                     FontSize="12" />
            </Border>
          </VerticalStackLayout>
        </Grid>
      </Border>

      <Border IsVisible="{Binding ShowDataSourceBanner}"
              Padding="16"
              Stroke="#D5DEE8"
              StrokeThickness="1"
              Background="#FFF8E8">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="18" />
        </Border.StrokeShape>
        <VerticalStackLayout Spacing="4">
          <Label Text="{Binding DataSourceTitle}"
                 Style="{StaticResource BodyTitleStyle}"
                 FontSize="18" />
          <Label Text="{Binding DataSourceMessage}"
                 Style="{StaticResource BodyTextStyle}"
                 TextColor="{StaticResource DashboardText}" />
        </VerticalStackLayout>
      </Border>

      <Border Padding="18"
              Stroke="#D5DEE8"
              StrokeThickness="1"
              Background="{StaticResource DashboardSurfaceStrong}">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="22" />
        </Border.StrokeShape>
        <VerticalStackLayout Spacing="14">
          <Label Text="{Binding DataReadinessTitle}"
                 Style="{StaticResource BodyTitleStyle}" />
          <Label Text="{Binding DataReadinessMessage}"
                 Style="{StaticResource BodyTextStyle}"
                 TextColor="{StaticResource DashboardText}" />
          <FlexLayout Direction="Row"
                      Wrap="Wrap"
                      AlignItems="Start"
                      BindableLayout.ItemsSource="{Binding DataReadinessItems}">
            <BindableLayout.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,0,12,12"
                        FlexLayout.Basis="210"
                        FlexLayout.Grow="1"
                        Padding="14"
                        Stroke="#D5DEE8"
                        StrokeThickness="1"
                        Background="{StaticResource DashboardSurface}">
                  <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                  </Border.StrokeShape>
                  <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <Label Text="{Binding Label}"
                             Style="{StaticResource SectionHeaderStyle}" />
                      <Label Grid.Column="1"
                             Text="{Binding Status}"
                             FontSize="13"
                             FontAttributes="Bold"
                             TextColor="{StaticResource DashboardText}" />
                    </Grid>
                    <Label Text="{Binding Detail}"
                           Style="{StaticResource BodyTextStyle}"
                           TextColor="{StaticResource DashboardText}" />
                  </VerticalStackLayout>
                </Border>
              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </FlexLayout>
        </VerticalStackLayout>
      </Border>

      <FlexLayout Direction="Row"
                  Wrap="Wrap"
                  AlignItems="Start"
                  JustifyContent="SpaceBetween">
        <VerticalStackLayout FlexLayout.Basis="350"
                             FlexLayout.Grow="1"
                             Spacing="16">
          <Border Stroke="#D5DEE8"
                  StrokeThickness="1"
                  Background="{StaticResource DashboardSurfaceStrong}">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Border.Shadow>
              <Shadow Brush="#32465C"
                      Offset="0,10"
                      Radius="18"
                      Opacity="0.10" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="0">
              <Border Background="{StaticResource DashboardNavyDark}"
                      StrokeThickness="0"
                      Padding="18,14">
                <Border.StrokeShape>
                  <RoundRectangle CornerRadius="22,22,0,0" />
                </Border.StrokeShape>
                <Label Text="Training Desk"
                       Style="{StaticResource CardTitleStyle}" />
              </Border>
              <VerticalStackLayout Padding="18" Spacing="12">
                <Label Text="Use this page to learn the main takeaway first: score, data age, and what-if risk."
                       Style="{StaticResource BodyTitleStyle}"
                       FontSize="17" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding TrainingDeskItems}"
                                     Spacing="10">
                  <BindableLayout.ItemTemplate>
                    <DataTemplate>
                      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="•"
                               FontSize="18"
                               TextColor="{StaticResource DashboardNavy}" />
                        <Label Grid.Column="1"
                               Text="{Binding .}"
                               Style="{StaticResource BodyTextStyle}"
                               TextColor="{StaticResource DashboardText}" />
                      </Grid>
                    </DataTemplate>
                  </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
              </VerticalStackLayout>
            </VerticalStackLayout>
          </Border>

          <FlexLayout Direction="Row"
                      Wrap="Wrap"
                      AlignItems="Start"
                      JustifyContent="SpaceBetween">
            <Border FlexLayout.Basis="170"
                    FlexLayout.Grow="1"
                    Margin="0,0,12,0"
                    Stroke="#D5DEE8"
                    StrokeThickness="1"
                    Background="{StaticResource DashboardSurfaceStrong}">
              <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
              </Border.StrokeShape>
              <VerticalStackLayout Spacing="0">
                <Border Background="{StaticResource DashboardNavy}"
                        StrokeThickness="0"
                        Padding="18,14">
                  <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22,22,0,0" />
                  </Border.StrokeShape>
                  <Label Text="Current Setup"
                         Style="{StaticResource CardTitleStyle}" />
                </Border>
                <VerticalStackLayout Padding="18" Spacing="10">
                  <Label Text="{Binding LeadSymbol}"
                         FontSize="30"
                         FontAttributes="Bold"
                         TextColor="{StaticResource DashboardText}" />
                  <Label Text="{Binding LeadHeadline}"
                         FontSize="14"
                         TextColor="{StaticResource DashboardSlate}" />
                  <BoxView HeightRequest="1"
                           Color="{StaticResource DashboardLine}" />
                  <Label Text="{Binding LeadScoreText}"
                         FontSize="15"
                         TextColor="{StaticResource DashboardText}" />
                  <Label Text="{Binding LeadLagText}"
                         FontSize="15"
                         TextColor="{StaticResource DashboardDanger}" />
                  <Label Text="{Binding LeadThemesText}"
                         Style="{StaticResource BodyTextStyle}" />
                </VerticalStackLayout>
              </VerticalStackLayout>
            </Border>

            <Border FlexLayout.Basis="170"
                    FlexLayout.Grow="1"
                    Stroke="#D5DEE8"
                    StrokeThickness="1"
                    Background="{StaticResource DashboardSurfaceStrong}">
              <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
              </Border.StrokeShape>
              <VerticalStackLayout Spacing="0">
                <Border Background="{StaticResource DashboardNavy}"
                        StrokeThickness="0"
                        Padding="18,14">
                  <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22,22,0,0" />
                  </Border.StrokeShape>
                  <Label Text="Quick Read"
                         Style="{StaticResource CardTitleStyle}" />
                </Border>
                <VerticalStackLayout Padding="18" Spacing="12"
                                     BindableLayout.ItemsSource="{Binding SignalFacts}">
                  <BindableLayout.ItemTemplate>
                    <DataTemplate>
                      <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding Label}"
                               Style="{StaticResource SectionHeaderStyle}" />
                        <Label Text="{Binding Value}"
                               FontSize="14"
                               TextColor="{StaticResource DashboardText}" />
                        <BoxView HeightRequest="1"
                                 Color="{StaticResource DashboardLine}" />
                      </VerticalStackLayout>
                    </DataTemplate>
                  </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
              </VerticalStackLayout>
            </Border>
          </FlexLayout>
        </VerticalStackLayout>

        <VerticalStackLayout FlexLayout.Basis="560"
                             FlexLayout.Grow="1"
                             Margin="16,0"
                             Spacing="16">
          <Border Stroke="#D5DEE8"
                  StrokeThickness="1"
                  Background="{StaticResource DashboardSurfaceStrong}">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <Border.Shadow>
              <Shadow Brush="#32465C"
                      Offset="0,10"
                      Radius="18"
                      Opacity="0.10" />
            </Border.Shadow>
            <VerticalStackLayout Spacing="0">
              <Border Background="{StaticResource DashboardNavy}"
                      StrokeThickness="0"
                      Padding="18,14">
                <Border.StrokeShape>
                  <RoundRectangle CornerRadius="22,22,0,0" />
                </Border.StrokeShape>
                <Label Text="Market Monitor"
                       Style="{StaticResource CardTitleStyle}" />
              </Border>
              <VerticalStackLayout Padding="18" Spacing="16">
                <Label Text="Market Overview"
                       Style="{StaticResource BodyTitleStyle}" />

                <FlexLayout Direction="Row"
                            Wrap="Wrap"
                            AlignItems="Start"
                            BindableLayout.ItemsSource="{Binding OverviewTiles}">
                  <BindableLayout.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,10,10"
                              FlexLayout.Basis="122"
                              FlexLayout.Grow="1"
                              Padding="12"
                              Stroke="#D5DEE8"
                              StrokeThickness="1"
                              Background="{StaticResource DashboardSurface}">
                        <Border.StrokeShape>
                          <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                          <Label Text="{Binding Label}"
                                 Style="{StaticResource SectionHeaderStyle}" />
                          <Label Text="{Binding Value}"
                                 Style="{StaticResource MetricValueStyle}" />
                          <Label Text="{Binding Delta}"
                                 Style="{StaticResource BodyTextStyle}" />
                        </VerticalStackLayout>
                      </Border>
                    </DataTemplate>
                  </BindableLayout.ItemTemplate>
                </FlexLayout>

                <VerticalStackLayout Spacing="10">
                  <Label Text="Price path"
                         Style="{StaticResource BodyTitleStyle}" />
                  <ContentView x:Name="TrendChartHost"
                               MinimumHeightRequest="270" />
                </VerticalStackLayout>

                <Border Padding="14"
                        Stroke="#D5DEE8"
                        StrokeThickness="1"
                        Background="{StaticResource DashboardSurface}">
                  <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                  </Border.StrokeShape>
                  <Label Text="{Binding MarketHeadline}"
                         FontSize="14"
                         TextColor="{StaticResource DashboardText}" />
                </Border>

                <Grid ColumnDefinitions="2*,*"
                      ColumnSpacing="14">
                  <ContentView x:Name="IndicatorChartHost"
                               Grid.Column="0"
                               MinimumHeightRequest="170" />
                  <Border Grid.Column="1"
                          Padding="14"
                          Stroke="#D5DEE8"
                          StrokeThickness="1"
                          Background="{StaticResource DashboardSurface}">
                    <Border.StrokeShape>
                      <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                      <Label Text="Desk Note"
                             Style="{StaticResource SectionHeaderStyle}" />
                      <Label Text="{Binding SentimentSummary}"
                             FontSize="14"
                             TextColor="{StaticResource DashboardText}" />
                      <Label Text="Higher fit score usually means a stronger match to the current checks."
                             Style="{StaticResource BodyTextStyle}" />
                      <Label Text="Older data lowers confidence."
                             Style="{StaticResource BodyTextStyle}" />
                      <Label Text="Forecasts are practice estimates, not certainties."
                             Style="{StaticResource BodyTextStyle}" />
                    </VerticalStackLayout>
                  </Border>
                </Grid>
              </VerticalStackLayout>
            </VerticalStackLayout>
          </Border>
        </VerticalStackLayout>

        <VerticalStackLayout FlexLayout.Basis="330"
                             FlexLayout.Grow="1"
                             Spacing="16">
          <Border Stroke="#D5DEE8"
                  StrokeThickness="1"
                  Background="{StaticResource DashboardSurfaceStrong}">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="0">
              <Border Background="{StaticResource DashboardNavy}"
                      StrokeThickness="0"
                      Padding="18,14">
                <Border.StrokeShape>
                  <RoundRectangle CornerRadius="22,22,0,0" />
                </Border.StrokeShape>
                <Label Text="What-If &amp; Forecast"
                       Style="{StaticResource CardTitleStyle}" />
              </Border>
              <VerticalStackLayout Padding="18" Spacing="12">
                <Label Text="What-if Scenario"
                       Style="{StaticResource BodyTitleStyle}" />
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding ScenarioFacts}"
                                     Spacing="12">
                  <BindableLayout.ItemTemplate>
                    <DataTemplate>
                      <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding Label}"
                               Style="{StaticResource SectionHeaderStyle}" />
                        <Label Text="{Binding Value}"
                               FontSize="14"
                               TextColor="{StaticResource DashboardText}" />
                        <BoxView HeightRequest="1"
                                 Color="{StaticResource DashboardLine}" />
                      </VerticalStackLayout>
                    </DataTemplate>
                  </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
              </VerticalStackLayout>
            </VerticalStackLayout>
          </Border>

          <Border Stroke="#D5DEE8"
                  StrokeThickness="1"
                  Background="{StaticResource DashboardSurfaceStrong}">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="0">
              <Border Background="{StaticResource DashboardNavyDark}"
                      StrokeThickness="0"
                      Padding="18,14">
                <Border.StrokeShape>
                  <RoundRectangle CornerRadius="22,22,0,0" />
                </Border.StrokeShape>
                <Label Text="Risk Rules"
                       Style="{StaticResource CardTitleStyle}" />
              </Border>
              <VerticalStackLayout Padding="18"
                                   Spacing="12"
                                   BindableLayout.ItemsSource="{Binding RiskRules}">
                <BindableLayout.ItemTemplate>
                  <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                      <Label Text="•"
                             FontSize="18"
                             TextColor="{StaticResource DashboardNavy}" />
                      <Label Grid.Column="1"
                             Text="{Binding .}"
                             Style="{StaticResource BodyTextStyle}"
                             TextColor="{StaticResource DashboardText}" />
                    </Grid>
                  </DataTemplate>
                </BindableLayout.ItemTemplate>
              </VerticalStackLayout>
            </VerticalStackLayout>
          </Border>

          <Border Stroke="#D5DEE8"
                  StrokeThickness="1"
                  Background="{StaticResource DashboardSurfaceStrong}">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="0">
              <Border Background="{StaticResource DashboardNavyDark}"
                      StrokeThickness="0"
                      Padding="18,14">
                <Border.StrokeShape>
                  <RoundRectangle CornerRadius="22,22,0,0" />
                </Border.StrokeShape>
                <Label Text="Quick Guide"
                       Style="{StaticResource CardTitleStyle}" />
              </Border>
              <VerticalStackLayout Padding="18" Spacing="10">
                <Label Text="Fit score: higher usually means the idea matches the current checks better."
                       Style="{StaticResource BodyTextStyle}"
                       TextColor="{StaticResource DashboardText}" />
                <Label Text="Data age: how many days old the newest saved price is."
                       Style="{StaticResource BodyTextStyle}"
                       TextColor="{StaticResource DashboardText}" />
                <Label Text="What-if: a practice test for one market shock."
                       Style="{StaticResource BodyTextStyle}"
                       TextColor="{StaticResource DashboardText}" />
                <Label Text="Options note: gains and losses can both speed up fast."
                       Style="{StaticResource BodyTextStyle}"
                       TextColor="{StaticResource DashboardText}" />
              </VerticalStackLayout>
            </VerticalStackLayout>
          </Border>
        </VerticalStackLayout>
      </FlexLayout>

      <Border Stroke="#D5DEE8"
              StrokeThickness="1"
              Background="{StaticResource DashboardSurfaceStrong}">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="22" />
        </Border.StrokeShape>
        <Border.Shadow>
          <Shadow Brush="#32465C"
                  Offset="0,10"
                  Radius="18"
                  Opacity="0.08" />
        </Border.Shadow>
        <VerticalStackLayout Spacing="0">
          <Border Background="{StaticResource DashboardNavy}"
                  StrokeThickness="0"
                  Padding="18,14">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22,22,0,0" />
            </Border.StrokeShape>
            <Label Text="Watchlist"
                   Style="{StaticResource CardTitleStyle}" />
          </Border>
          <VerticalStackLayout Padding="18" Spacing="14">
              <Label Text="{Binding WatchlistCaption}"
                     Style="{StaticResource BodyTextStyle}" />
            <Grid ColumnDefinitions="1.1*,0.9*,0.9*,2.1*"
                  ColumnSpacing="12">
              <Label Text="Symbol"
                     Style="{StaticResource SectionHeaderStyle}" />
              <Label Grid.Column="1"
                     Text="Fit"
                     Style="{StaticResource SectionHeaderStyle}" />
              <Label Grid.Column="2"
                     Text="Age"
                     Style="{StaticResource SectionHeaderStyle}" />
              <Label Grid.Column="3"
                     Text="Themes"
                     Style="{StaticResource SectionHeaderStyle}" />
            </Grid>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding TopSymbols}"
                                 Spacing="10">
              <BindableLayout.ItemTemplate>
                <DataTemplate>
                  <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="1.1*,0.9*,0.9*,2.1*"
                          ColumnSpacing="12">
                      <Label Text="{Binding Symbol}"
                             FontSize="16"
                             FontAttributes="Bold"
                             TextColor="{StaticResource DashboardText}" />
                      <Label Grid.Column="1"
                             Text="{Binding Score, StringFormat='{}{0:F2}'}"
                             FontSize="15"
                             TextColor="{StaticResource DashboardText}" />
                      <Label Grid.Column="2"
                             Text="{Binding LagDays, StringFormat='{}{0}d'}"
                             FontSize="15"
                             TextColor="{StaticResource DashboardDanger}" />
                      <Label Grid.Column="3"
                             Text="{Binding ThemeLabels}"
                             FontSize="14"
                             TextColor="{StaticResource DashboardSlate}"
                             LineBreakMode="TailTruncation" />
                    </Grid>
                    <BoxView HeightRequest="1"
                             Color="{StaticResource DashboardLine}" />
                  </VerticalStackLayout>
                </DataTemplate>
              </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
          </VerticalStackLayout>
        </VerticalStackLayout>
      </Border>

      <Border Stroke="#D5DEE8"
              StrokeThickness="1"
              Background="{StaticResource DashboardSurfaceStrong}">
        <Border.StrokeShape>
          <RoundRectangle CornerRadius="22" />
        </Border.StrokeShape>
        <VerticalStackLayout Spacing="0">
          <Border Background="{StaticResource DashboardNavyDark}"
                  StrokeThickness="0"
                  Padding="18,14">
            <Border.StrokeShape>
              <RoundRectangle CornerRadius="22,22,0,0" />
            </Border.StrokeShape>
            <Label Text="Recent Logs"
                   Style="{StaticResource CardTitleStyle}" />
          </Border>
          <VerticalStackLayout Padding="18"
                               Spacing="10"
                               BindableLayout.ItemsSource="{Binding RecentLogs}">
            <BindableLayout.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="Auto,Auto,*"
                      ColumnSpacing="10">
                  <Label Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                         Style="{StaticResource BodyTextStyle}"
                         TextColor="{StaticResource DashboardSlate}" />
                  <Label Grid.Column="1"
                         Text="{Binding Level}"
                         FontSize="12"
                         FontAttributes="Bold"
                         TextColor="{StaticResource DashboardText}" />
                  <Label Grid.Column="2"
                         Text="{Binding Message}"
                         Style="{StaticResource BodyTextStyle}"
                         TextColor="{StaticResource DashboardText}"
                         LineBreakMode="TailTruncation" />
                </Grid>
              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>
        </VerticalStackLayout>
      </Border>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
