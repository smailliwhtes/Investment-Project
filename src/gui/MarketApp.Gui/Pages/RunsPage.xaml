<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MarketApp.Gui.Pages.RunsPage"
             Title="Runs">
  <ContentPage.Resources>
    <ResourceDictionary>
      <Style x:Key="InfoIconButtonStyle" TargetType="Button">
        <Setter Property="Text" Value="i" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="MinimumWidthRequest" Value="22" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="22" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="BackgroundColor" Value="#2F2F2F" />
        <Setter Property="BorderColor" Value="#4E6FA4" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="#FFFFFF" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">
      <HorizontalStackLayout Spacing="6">
        <Label Text="Run history" FontSize="22" FontAttributes="Bold" />
        <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="run_history" Clicked="OnInfoClicked" />
      </HorizontalStackLayout>

      <Frame>
        <VerticalStackLayout Spacing="6">
          <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,0,0,4">
            <Label Text="Run id" FontAttributes="Bold" />
            <Label Text="Started" Grid.Column="1" FontAttributes="Bold" />
            <Label Text="Finished" Grid.Column="2" FontAttributes="Bold" />
            <Label Text="Universe" Grid.Column="3" FontAttributes="Bold" />
            <Label Text="Eligible" Grid.Column="4" FontAttributes="Bold" />
          </Grid>

          <ScrollView HeightRequest="180">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Runs}" Spacing="2">
              <BindableLayout.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,2" MinimumHeightRequest="24">
                    <Label Text="{Binding RunId}" LineBreakMode="TailTruncation" MaxLines="1" />
                    <Label Text="{Binding StartedAt, StringFormat='{}{0:MM-dd HH:mm}'}" Grid.Column="1" />
                    <Label Text="{Binding FinishedAt, StringFormat='{}{0:MM-dd HH:mm}'}" Grid.Column="2" />
                    <Label Text="{Binding UniverseCount}" Grid.Column="3" />
                    <Label Text="{Binding EligibleCount}" Grid.Column="4" />
                  </Grid>
                </DataTemplate>
              </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
          </ScrollView>
        </VerticalStackLayout>
      </Frame>

      <Frame>
        <VerticalStackLayout Spacing="8">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Run comparison" FontAttributes="Bold" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="run_compare" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>

          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <VerticalStackLayout>
              <HorizontalStackLayout Spacing="6">
                <Label Text="Run A" />
                <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="run_a" Clicked="OnInfoClicked" />
              </HorizontalStackLayout>
              <Picker ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRunA}" ItemDisplayBinding="{Binding RunId}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1">
              <HorizontalStackLayout Spacing="6">
                <Label Text="Run B" />
                <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="run_b" Clicked="OnInfoClicked" />
              </HorizontalStackLayout>
              <Picker ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRunB}" ItemDisplayBinding="{Binding RunId}" />
            </VerticalStackLayout>
          </Grid>

          <HorizontalStackLayout Spacing="8">
            <Button Text="Refresh" Command="{Binding RefreshCommand}" />
            <Button Text="Compare" Command="{Binding CompareCommand}" />
          </HorizontalStackLayout>

          <Label Text="{Binding Status}" />
          <Label Text="{Binding DiffSummary}" />

          <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,0,0,4">
            <Label Text="Symbol" FontAttributes="Bold" />
            <Label Text="Delta score" Grid.Column="1" FontAttributes="Bold" />
            <Label Text="Delta rank" Grid.Column="2" FontAttributes="Bold" />
            <Label Text="Flags A" Grid.Column="3" FontAttributes="Bold" />
            <Label Text="Flags B" Grid.Column="4" FontAttributes="Bold" />
          </Grid>

          <ScrollView HeightRequest="220">
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding DiffRows}" Spacing="2">
              <BindableLayout.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,2" MinimumHeightRequest="24">
                    <Label Text="{Binding Symbol}" />
                    <Label Text="{Binding DeltaScore, StringFormat='{}{0:F4}'}" Grid.Column="1" />
                    <Label Text="{Binding DeltaRank}" Grid.Column="2" />
                    <Label Text="{Binding FlagsA}" Grid.Column="3" />
                    <Label Text="{Binding FlagsB}" Grid.Column="4" />
                  </Grid>
                </DataTemplate>
              </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
          </ScrollView>
        </VerticalStackLayout>
      </Frame>

      <Frame>
        <VerticalStackLayout Spacing="6">
          <HorizontalStackLayout Spacing="6">
            <Label Text="Run A quality" FontAttributes="Bold" />
            <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="run_a_quality" Clicked="OnInfoClicked" />
          </HorizontalStackLayout>

          <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,0,0,4">
            <Label Text="Model" FontAttributes="Bold" />
            <Label Text="MSE" Grid.Column="1" FontAttributes="Bold" />
            <Label Text="MAE" Grid.Column="2" FontAttributes="Bold" />
            <Label Text="Accuracy" Grid.Column="3" FontAttributes="Bold" />
            <Label Text="F1" Grid.Column="4" FontAttributes="Bold" />
          </Grid>

          <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedRunMetrics}" Spacing="2">
            <BindableLayout.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,2" MinimumHeightRequest="24">
                  <Label Text="{Binding Model}" LineBreakMode="TailTruncation" MaxLines="1" />
                  <Label Text="{Binding Mse, StringFormat='{}{0:F4}'}" Grid.Column="1" />
                  <Label Text="{Binding Mae, StringFormat='{}{0:F4}'}" Grid.Column="2" />
                  <Label Text="{Binding Accuracy, StringFormat='{}{0:P1}'}" Grid.Column="3" />
                  <Label Text="{Binding F1, StringFormat='{}{0:P1}'}" Grid.Column="4" />
                </Grid>
              </DataTemplate>
            </BindableLayout.ItemTemplate>
          </VerticalStackLayout>
        </VerticalStackLayout>
      </Frame>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
