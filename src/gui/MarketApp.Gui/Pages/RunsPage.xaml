<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MarketApp.Gui.Pages.RunsPage"
             Title="Runs">
  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">
      <Label Text="Run history" FontSize="22" FontAttributes="Bold" />

      <CollectionView ItemsSource="{Binding Runs}" HeightRequest="260">
        <CollectionView.Header>
          <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,0,0,4">
            <Label Text="Run id" />
            <Label Text="Started" />
            <Label Text="Finished" />
            <Label Text="Universe" />
            <Label Text="Eligible" />
          </Grid>
        </CollectionView.Header>
        <CollectionView.ItemTemplate>
          <DataTemplate>
            <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,2">
              <Label Text="{Binding RunId}" />
              <Label Text="{Binding StartedAt, StringFormat='{}{0:MM-dd HH:mm}'}" />
              <Label Text="{Binding FinishedAt, StringFormat='{}{0:MM-dd HH:mm}'}" />
              <Label Text="{Binding UniverseCount}" />
              <Label Text="{Binding EligibleCount}" />
            </Grid>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>

      <Frame>
        <VerticalStackLayout Spacing="8">
          <Label Text="Run comparison" FontAttributes="Bold" />
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <VerticalStackLayout>
              <Label Text="Run A" />
              <Picker ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRunA}" ItemDisplayBinding="{Binding RunId}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1">
              <Label Text="Run B" />
              <Picker ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRunB}" ItemDisplayBinding="{Binding RunId}" />
            </VerticalStackLayout>
          </Grid>

          <HorizontalStackLayout Spacing="8">
            <Button Text="Refresh" Command="{Binding RefreshCommand}" />
            <Button Text="Compare" Command="{Binding CompareCommand}" />
          </HorizontalStackLayout>

          <Label Text="{Binding Status}" />
          <Label Text="{Binding DiffSummary}" />

          <CollectionView ItemsSource="{Binding DiffRows}" HeightRequest="260">
            <CollectionView.Header>
              <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,0,0,4">
                <Label Text="Symbol" />
                <Label Text="Delta score" />
                <Label Text="Delta rank" />
                <Label Text="Flags A" />
                <Label Text="Flags B" />
              </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,2">
                  <Label Text="{Binding Symbol}" />
                  <Label Text="{Binding DeltaScore, StringFormat='{}{0:F4}'}" />
                  <Label Text="{Binding DeltaRank}" />
                  <Label Text="{Binding FlagsA}" />
                  <Label Text="{Binding FlagsB}" />
                </Grid>
              </DataTemplate>
            </CollectionView.ItemTemplate>
          </CollectionView>
        </VerticalStackLayout>
      </Frame>

      <Frame>
        <VerticalStackLayout Spacing="4">
          <Label Text="Run A quality" FontAttributes="Bold" />
          <CollectionView ItemsSource="{Binding SelectedRunMetrics}" HeightRequest="140">
            <CollectionView.Header>
              <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,0,0,4">
                <Label Text="Model" />
                <Label Text="MSE" />
                <Label Text="MAE" />
                <Label Text="Accuracy" />
                <Label Text="F1" />
              </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="0,2">
                  <Label Text="{Binding Model}" />
                  <Label Text="{Binding Mse, StringFormat='{}{0:F4}'}" />
                  <Label Text="{Binding Mae, StringFormat='{}{0:F4}'}" />
                  <Label Text="{Binding Accuracy, StringFormat='{}{0:P1}'}" />
                  <Label Text="{Binding F1, StringFormat='{}{0:P1}'}" />
                </Grid>
              </DataTemplate>
            </CollectionView.ItemTemplate>
          </CollectionView>
        </VerticalStackLayout>
      </Frame>
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
