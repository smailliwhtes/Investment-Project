<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MarketApp.Gui.Pages.LogsPage"
             Title="Logs">
  <ContentPage.Resources>
    <ResourceDictionary>
      <Style x:Key="InfoIconButtonStyle" TargetType="Button">
        <Setter Property="Text" Value="i" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="WidthRequest" Value="22" />
        <Setter Property="MinimumWidthRequest" Value="22" />
        <Setter Property="HeightRequest" Value="22" />
        <Setter Property="MinimumHeightRequest" Value="22" />
        <Setter Property="CornerRadius" Value="11" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="BackgroundColor" Value="#2F2F2F" />
        <Setter Property="BorderColor" Value="#4E6FA4" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="TextColor" Value="#FFFFFF" />
      </Style>

      <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <VerticalStackLayout Padding="18" Spacing="14">
    <HorizontalStackLayout Spacing="6">
      <Label Text="Engine &amp; UI logs" Style="{StaticResource PageTitleStyle}" />
      <Button Style="{StaticResource InfoIconButtonStyle}" CommandParameter="logs" Clicked="OnInfoClicked" />
    </HorizontalStackLayout>
    <Label Text="Use this page only when something fails. Warnings mean caution; errors mean a step stopped." FontSize="13" />

    <Frame Padding="12">
      <Editor Text="{Binding CombinedLog}"
              FontSize="13"
              AutoSize="TextChanges"
              IsReadOnly="True"
              HeightRequest="480" />
    </Frame>
  </VerticalStackLayout>
</ContentPage>
